{
  "name": "dynamic-color-palette-generator",
  "version": "1.0.0",
  "description": "An application that generates a random color palette on demand, allowing users to lock individual colors and copy hex codes to their clipboard. This project is part of a larger interconnected system, designed to integrate with services like the HTML Canvas Drawing Board, Live Markdown Editor, and Interactive Kanban Board.",
  "main": "index.html",
  "scripts": {
    "start": "parcel index.html --open",
    "build": "parcel build index.html --public-url ./",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky install"
  },
  "keywords": [
    "color-palette",
    "generator",
    "javascript",
    "html",
    "css",
    "frontend",
    "web-app",
    "microservice-context",
    "drawing-board-integration",
    "markdown-editor-context",
    "kanban-board-utility"
  ],
  "author": "Your Name/Organization",
  "license": "MIT",
  "devDependencies": {
    "@parcel/transformer-sass": "^2.12.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "parcel": "^2.12.0",
    "prettier": "^3.2.5"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "node": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:prettier/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "warn",
      "prettier/prettier": [
        "error",
        {
          "endOfLine": "auto"
        }
      ]
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,json,css,scss,md,html}": "prettier --write"
  }
}